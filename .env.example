# =============================================================================
# VANGUARD-X Blue Team SecOps — Local environment overrides
# Copy to `.env` (Compose auto-loads) and edit. Never commit `.env` itself.
# =============================================================================

# -----------------------------------------------------------------------------
# Local LLM (Ollama, OpenAI-compatible /v1)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama-service:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b
# Required by the OpenAI SDK contract; Ollama itself ignores it.
OLLAMA_API_KEY=ollama-local-noop

# -----------------------------------------------------------------------------
# Pipeline behaviour
# -----------------------------------------------------------------------------
MAX_AGENT_TURNS=18
REQUEST_TIMEOUT_S=240
LOG_LEVEL=INFO

# Path to the SIEM/EDR event batch the LogIngestAgent will process.
# This file MUST already exist on disk — VANGUARD-X never reaches out to
# third-party networks to fetch logs.
SIEM_EVENTS_PATH=/home/secops/app/sample_data/siem_events.json

# -----------------------------------------------------------------------------
# Human approval gate (MANDATORY — non-negotiable policy)
# -----------------------------------------------------------------------------
# Modes:
#   interactive   -> prompts a human via stdin; blocks until decision (default)
#   auto_reject   -> always rejects; safe for CI / smoke tests
# There is intentionally NO `auto_approve` mode. If you need to bypass the
# gate for development you must explicitly type APPROVE on stdin every run.
HUMAN_APPROVAL_MODE=interactive

# Hard timeout (seconds) for the human to respond. On timeout the gate
# auto-rejects (fail-closed). Set to 0 to wait indefinitely.
HUMAN_APPROVAL_TIMEOUT_S=600

# -----------------------------------------------------------------------------
# Notification channels — fired ONLY after a human APPROVE on the gate.
# Leave any of them empty to disable that channel; an empty configuration
# is valid (the report is still persisted to disk).
# -----------------------------------------------------------------------------

# Telegram Bot — create via @BotFather, then add it to a chat and capture
# the chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord channel webhook — Server Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Optional: override the audit prompt without rebuilding the image.
# When unset, main.py builds a prompt automatically from SIEM_EVENTS_PATH.
# -----------------------------------------------------------------------------
# SECOPS_TASK="Triage the attached SIEM batch focusing on lateral-movement indicators."
