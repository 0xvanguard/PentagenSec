# =============================================================================
# VANGUARD-X — Local environment overrides
# Copy to `.env` (Compose auto-loads it) and edit as needed.
# =============================================================================

# --- LLM endpoint -------------------------------------------------------------
# Ollama exposes an OpenAI-compatible API at /v1 on port 11434.
OLLAMA_BASE_URL=http://ollama-service:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b
# Required by the OpenAI SDK contract; Ollama itself ignores it.
OLLAMA_API_KEY=ollama-local-noop

# --- Pipeline behaviour -------------------------------------------------------
# Hard cap on agent turns (Recon+Scanner+ThreatIntel+SOC+Auditor + slack).
MAX_AGENT_TURNS=20
# Per-LLM-call timeout in seconds (raise on slow CPUs / first-token latency).
REQUEST_TIMEOUT_S=240
LOG_LEVEL=INFO

# --- Custom scenario ----------------------------------------------------------
# When set, replaces the built-in DEFAULT_TASK in main.py. Keep it on a single
# line or wrap with quotes.
# SECOPS_TASK="Audit the security posture of api.staging.acme.io which exposes /debug and /metrics without authentication."
